{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.lacausecrypto/sophon",
  "title": "Sophon",
  "description": "Honest token economics for MCP agents. Rust binary, zero ML, reproducible benchmarks.",
  "version": "0.3.0",
  "repository": {
    "url": "https://github.com/lacausecrypto/mcp-sophon",
    "source": "github"
  },
  "websiteUrl": "https://github.com/lacausecrypto/mcp-sophon#readme",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "mcp-sophon",
      "version": "0.3.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "serve",
          "description": "Start the Sophon MCP stdio server."
        }
      ]
    }
  ],
  "_meta": {
    "io.github.lacausecrypto/sophon": {
      "license": "MIT",
      "language": "rust",
      "tools": [
        "compress_prompt",
        "compress_history",
        "compress_output",
        "navigate_codebase",
        "update_memory",
        "read_file_delta",
        "write_file_delta",
        "encode_fragments",
        "decode_fragments",
        "count_tokens",
        "get_token_stats"
      ],
      "optionalFeatures": {
        "semanticRetriever": "Activated via SOPHON_RETRIEVER_PATH env var. Adds query-time retrieval to compress_history and drives the +13-point LOCOMO open-ended gain measured at N=60. Deterministic HashEmbedder (no ML at runtime). See BENCHMARK.md § 3.7.",
        "treeSitter": "Activated via cargo feature codebase-navigator/tree-sitter. Swaps the regex extractors for AST-accurate parsing across 11 languages (Rust, Python, JS, TS, TSX, Go, Ruby, Java, C/C++, PHP, Kotlin, Swift). +8 MB in the binary, parallelised via rayon. See BENCHMARK.md § 7.8.a."
      },
      "tokenizer": "cl100k_base",
      "benchmarks": {
        "session_total_token_savings_pct": 67,
        "cross_model_total_token_savings_pct": 64.5,
        "locomo_comp_llm_accuracy_pct_n80": 40,
        "locomo_retrieval_accuracy_pct_n80": 32.5,
        "locomo_full_ceiling_pct_n80": 71.2,
        "locomo_comp_llm_beats_retriever_by_pts": 7.5,
        "locomo_multihop_accuracy_all_conditions": 0,
        "bge_matches_mem0lite_at_zero_llm_calls": true,
        "vs_llmlingua2_pts_better_on_structured_prompts": 8.9,
        "vs_llmlingua2_latency_speedup_x": 35,
        "vs_mem0_lite_locomo_accuracy_tie_pct": 60,
        "vs_mem0_lite_latency_ratio_sophon_over_mem0": "sub-second vs 8.7 min",
        "compression_overhead_ms_per_call": 6
      },
      "benchmarksUrl": "https://github.com/lacausecrypto/mcp-sophon/blob/main/BENCHMARK.md"
    }
  }
}
