    "mcp",
    "model-context-protocol",
    "llm",
    "token-compression",
    "prompt-compression",
    "conversation-memory",
    "codebase-navigation",
    "claude",
    "claude-code",
    "anthropic",
    "codex",
    "agent-context",
    "deterministic",
    "rust",
    "cl100k_base"
  ],
  "homepage": "https://github.com/lacausecrypto/mcp-sophon#readme",
  "bugs": {
    "url": "https://github.com/lacausecrypto/mcp-sophon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lacausecrypto/mcp-sophon.git",
    "directory": "npm"
  },
  "license": "MIT",
  "author": "Sophon Contributors",
  "bin": {
    "sophon": "bin/sophon.js"
  },
  "files": [
    "bin/sophon.js",
