# Rust
target/
**/target/
Cargo.lock.bak
*.rs.bk

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# npm wrapper — downloaded binaries
npm/vendor/
npm/bin/sophon
npm/bin/sophon.exe

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Local state
*.log
*.tmp
/fragments-store.json
~/.sophon/

# Editor
.vscode/
.idea/
*.iml

# Claude Code local state — never commit
.claude/
CLAUDE.md

# Python virtual environments + build artifacts
.venv/
**/.venv/
__pycache__/
*.pyc
*.egg-info/
*.so
*.pyd
*.dll
sophon-py/target/

# ML model caches (downloaded on first use)
.fastembed_cache/
**/.fastembed_cache/

# Benchmark artifacts (large + regenerated, user-provided)
/tmp/sophon_bench/
benchmarks/data/
benchmarks/*.json
!benchmarks/*.py
!benchmarks/*.md

# MCP registry auth tokens — NEVER commit, they grant publish rights
.mcpregistry_*
